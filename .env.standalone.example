# ==========================================
# HOTEL BOOKING - STANDALONE ENVIRONMENT
# ==========================================

# Core Application Settings
NODE_ENV=production
PORT=4000
WEB_PORT=3000

# Public URLs (Replace with actual domain in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql

# Database Configuration (Docker network mapping)
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=hoteldb
DATABASE_URL=postgresql://admin:secretpassword@postgres:5432/hoteldb?schema=public

# Redis Configuration (Docker network mapping)
REDIS_PASSWORD=secretredis
REDIS_HOST=redis
REDIS_PORT=6379

# Authentication Secrets (GENERATE NEW SECRETS FOR PRODUCTION)
# Use `openssl rand -base64 32` to generate
JWT_SECRET=super_secret_for_standalone_platform_must_change
JWT_REFRESH_SECRET=super_secret_refresh_for_standalone_platform

# CORS (Allowed domains for the API)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: SMTP Configuration (For transactional emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Hotel Admin <noreply@hotel.com>"

# Optional: Payment Gateway (Razorpay)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Disable Multi-tenant aggregator requirements
AGGREGATOR_DOMAIN=localhost
API_DOMAIN=localhost
